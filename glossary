<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Phoenix Glossary</title>
  <style>
    body { 
      font-family: system-ui, sans-serif; 
      background: #0f0f0f; 
      color: #ddd; 
      margin: 0; 
      padding: 20px; 
    }
    h1 { color: #00ddff; }
    .admin-btn { 
      background: #ffaa00; 
      color: #000; 
      padding: 12px 24px; 
      border: none; 
      border-radius: 6px; 
      cursor: pointer; 
      font-size: 1.1rem; 
      margin: 10px 0; 
    }
    input { 
      width: 100%; 
      padding: 12px; 
      margin: 20px 0; 
      background: #1a1a1a; 
      color: #ddd; 
      border: 1px solid #444; 
      border-radius: 6px; 
      font-size: 1.05rem; 
    }
    table { 
      width: 100%; 
      border-collapse: collapse; 
      background: #1a1a1a; 
      margin-top: 10px; 
    }
    th, td { 
      padding: 12px; 
      text-align: left; 
      border-bottom: 1px solid #333; 
    }
    th { 
      background: #222; 
      position: sticky; 
      top: 0; 
    }
    tr:hover { background: #252525; }
    .name-col { width: 25%; font-weight: 500; }
    #status { margin: 15px 0; font-style: italic; color: #aaa; }
  </style>
</head>
<body>
  <h1>Phoenix Glossary <small style="color:#666;">(~578 items)</small></h1>
  
  <button class="admin-btn" onclick="window.open('https://github.com/jwl247/Phoenix-Package_handler', '_blank')">
    🔧 Admin → GitHub Repo
  </button>

  <input type="text" id="search" placeholder="Search by name, hex, or description..." onkeyup="filterTable()">

  <div id="status">Loading glossary from worker...</div>
  
  <table id="glossaryTable">
    <thead>
      <tr>
        <th class="name-col">Name</th>
        <th>Hex</th>
        <th>Description</th>
        <th>State</th>
        <th>Intake Date</th>
        <th>Size</th>
      </tr>
    </thead>
    <tbody></tbody>
  </table>

  <script>
    const workerUrl = "https://packages-worker.phoenix-jwl.workers.dev";

    async function loadGlossary() {
      const status = document.getElementById("status");
      try {
        const res = await fetch(`${workerUrl}/glossary`);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);

        const responseData = await res.json();
        
        // Handle both possible formats safely
        let items = responseData.glossary || (Array.isArray(responseData) ? responseData : []);

        const tbody = document.querySelector("#glossaryTable tbody");
        tbody.innerHTML = "";

        if (items.length === 0) {
          status.textContent = "No items found.";
          return;
        }

        items.forEach(item => {
          const row = document.createElement("tr");
          row.innerHTML = `
            <td class="name-col">${item.name || "—"}</td>
            <td style="font-family: monospace; font-size: 0.85em; word-break: break-all;">${item.hex || "—"}</td>
            <td>${item.description || "—"}</td>
            <td>${item.state || "—"}</td>
            <td>${item.intaked_at ? item.intaked_at.substring(0, 16) : "—"}</td>
            <td>${item.size || "—"}</td>
          `;
          tbody.appendChild(row);
        });

        status.textContent = `✅ Loaded ${items.length} items successfully.`;
      } catch (e) {
        console.error(e);
        status.innerHTML = `❌ Failed to load.<br>Error: ${e.message}<br><br>Refresh the page or check F12 Console.`;
      }
    }

    function filterTable() {
      const term = document.getElementById("search").value.toLowerCase().trim();
      const rows = document.querySelectorAll("#glossaryTable tbody tr");
      rows.forEach(row => {
        row.style.display = (term === "" || row.textContent.toLowerCase().includes(term)) ? "" : "none";
      });
    }

    loadGlossary();
  </script>
</body>
</html>
