<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Phoenix Glossary</title>
  <style>
    body { font-family: system-ui, sans-serif; background: #0f0f0f; color: #ddd; margin: 0; padding: 20px; }
    h1 { color: #00ddff; }
    .admin-btn { background: #ffaa00; color: #000; padding: 12px 24px; border: none; border-radius: 6px; cursor: pointer; font-size: 1.1rem; margin: 10px 0; }
    input { width: 100%; padding: 12px; margin: 20px 0; background: #1a1a1a; color: #ddd; border: 1px solid #444; border-radius: 6px; font-size: 1.05rem; }
    table { width: 100%; border-collapse: collapse; background: #1a1a1a; margin-top: 10px; }
    th, td { padding: 12px; text-align: left; border-bottom: 1px solid #333; cursor: pointer; }
    th { background: #222; position: sticky; top: 0; }
    tr:hover { background: #252525; }
    .name-col { width: 30%; font-weight: 600; color: #00ddff; }
    #status { margin: 15px 0; font-style: italic; color: #aaa; }
    #detail-panel { background: #1a1a1a; padding: 20px; margin-top: 20px; border-radius: 8px; display: none; max-height: 600px; overflow: auto; }
    pre { background: #111; padding: 15px; overflow: auto; white-space: pre-wrap; }
  </style>
</head>
<body>
  <h1>Phoenix Glossary</h1>
  
  <button class="admin-btn" onclick="window.open('https://github.com/jwl247/Phoenix-Package_handler', '_blank')">
    🔧 Admin → GitHub Repo
  </button>

  <input type="text" id="search" placeholder="Search by readable name, hex, or description..." onkeyup="filterTable()">

  <div id="status">Loading glossary from worker...</div>
  
  <table id="glossaryTable">
    <thead>
      <tr>
        <th class="name-col">Readable Name</th>
        <th>Hex</th>
        <th>Description</th>
        <th>State</th>
        <th>Intake Date</th>
        <th>Size</th>
      </tr>
    </thead>
    <tbody></tbody>
  </table>

  <div id="detail-panel">
    <strong>Selected Entry Details + Code Attempt:</strong><br><br>
    <div id="detail-content"></div>
  </div>

  <script>
    const workerUrl = "https://packages-worker.phoenix-jwl.workers.dev";

    async function loadGlossary() {
      const status = document.getElementById("status");
      try {
        const res = await fetch(`${workerUrl}/glossary`);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);

        const data = await res.json();
        let items = data.glossary || (Array.isArray(data) ? data : []);

        const tbody = document.querySelector("#glossaryTable tbody");
        tbody.innerHTML = "";

        items.forEach(item => {
          const row = document.createElement("tr");
          row.innerHTML = `
            <td class="name-col">${item.name || "—"}</td>
            <td style="font-family: monospace; font-size: 0.85em;">${item.hex || "—"}</td>
            <td>${item.description || "—"}</td>
            <td>${item.state || "—"}</td>
            <td>${item.intaked_at ? item.intaked_at.substring(0,16) : "—"}</td>
            <td>${item.size || "—"}</td>
          `;
          row.onclick = () => showDetails(item);
          tbody.appendChild(row);
        });

        status.textContent = `✅ Loaded ${items.length} items. Click any row for details + code.`;
      } catch (e) {
        console.error(e);
        status.innerHTML = `❌ Failed to load glossary.<br>Error: ${e.message}<br><br>Try refreshing.`;
      }
    }

    async function showDetails(item) {
      const panel = document.getElementById("detail-panel");
      const content = document.getElementById("detail-content");
      
      let html = `
        <strong>Name:</strong> ${item.name || "—"}<br>
        <strong>Hex:</strong> ${item.hex || "—"}<br>
        <strong>Description:</strong> ${item.description || "—"}<br>
        <strong>Pool Path:</strong> ${item.pool_path || "—"}<br>
        <strong>Size:</strong> ${item.size || "—"} bytes<br>
        <strong>Intaked:</strong> ${item.intaked_at || "—"}<br><br>
      `;

      content.innerHTML = html + `<p><strong>Fetching code/content for this entry...</strong></p>`;

      panel.style.display = "block";

      // Try to load the actual code (change endpoint if your worker uses something different)
      if (item.hex) {
        try {
          const codeRes = await fetch(`${workerUrl}/code/${item.hex}`);
          if (codeRes.ok) {
            const codeText = await codeRes.text();
            content.innerHTML = html + `<pre>${codeText}</pre>`;
          } else {
            content.innerHTML = html + `<p style="color:#ffaa00;">No code endpoint available yet (or 404). You can add /code/:hex later.</p>`;
          }
        } catch (err) {
          content.innerHTML = html + `<p style="color:#ffaa00;">Could not load code (endpoint may not exist yet).</p>`;
        }
      }
    }

    function filterTable() {
      const term = document.getElementById("search").value.toLowerCase().trim();
      const rows = document.querySelectorAll("#glossaryTable tbody tr");
      rows.forEach(row => {
        row.style.display = (term === "" || row.textContent.toLowerCase().includes(term)) ? "" : "none";
      });
    }

    loadGlossary();
  </script>
</body>
</html>
