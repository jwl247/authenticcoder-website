<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Glossary — AuthenticCoder / USys</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0c0f;
    --surface: #0f1318;
    --border: #1e2530;
    --accent: #00ff9d;
    --accent2: #0066ff;
    --text: #c8d4e0;
    --muted: #4a5568;
    --danger: #ff4444;
    --mono: 'Share Tech Mono', monospace;
    --sans: 'Barlow', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: 
      linear-gradient(rgba(0,255,157,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,255,157,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 1;
  }

  /* Header */
  header {
    border-bottom: 1px solid var(--border);
    padding: 32px 0 24px;
    margin-bottom: 48px;
  }

  .header-inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .brand {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 8px;
    opacity: 0.8;
  }

  h1 {
    font-family: var(--mono);
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: #fff;
    line-height: 1;
  }

  h1 span {
    color: var(--accent);
  }

  .status-bar {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s infinite;
    display: inline-block;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* Search */
  .search-wrap {
    margin-bottom: 40px;
    position: relative;
  }

  .search-wrap::before {
    content: '>';
    font-family: var(--mono);
    color: var(--accent);
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 14px;
  }

  #search {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    color: var(--text);
    font-family: var(--mono);
    font-size: 14px;
    padding: 14px 16px 14px 36px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  #search:focus {
    border-color: var(--accent);
    box-shadow: 0 0 20px rgba(0,255,157,0.1);
  }

  #search::placeholder {
    color: var(--muted);
  }

  /* Filter tabs */
  .filters {
    display: flex;
    gap: 8px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .filter-btn {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 14px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    cursor: pointer;
    transition: all 0.15s;
  }

  .filter-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #000;
    font-weight: 700;
  }

  /* Stats row */
  .stats {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    margin-bottom: 24px;
    display: flex;
    gap: 24px;
  }

  .stats span { color: var(--accent); }

  /* Glossary grid */
  #glossary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .term-card {
    background: var(--surface);
    padding: 24px;
    transition: background 0.15s;
    animation: fadeIn 0.3s ease forwards;
    opacity: 0;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .term-card:hover {
    background: #131820;
  }

  .term-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }

  .term-name {
    font-family: var(--mono);
    font-size: 15px;
    color: #fff;
    font-weight: 400;
  }

  .term-category {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 3px 8px;
    border: 1px solid;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cat-core { color: var(--accent); border-color: rgba(0,255,157,0.3); }
  .cat-application { color: var(--accent2); border-color: rgba(0,102,255,0.3); }
  .cat-system { color: #ff9500; border-color: rgba(255,149,0,0.3); }
  .cat-storage { color: #bf5af2; border-color: rgba(191,90,242,0.3); }
  .cat-worker { color: #ff375f; border-color: rgba(255,55,95,0.3); }
  .cat-default { color: var(--muted); border-color: var(--border); }

  .term-def {
    font-size: 13px;
    line-height: 1.7;
    color: var(--text);
    font-weight: 300;
  }

  .term-hex {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted);
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }

  /* Access request section */
  .access-section {
    margin-top: 64px;
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent2);
    padding: 32px;
    background: var(--surface);
  }

  .access-section h2 {
    font-family: var(--mono);
    font-size: 14px;
    letter-spacing: 0.1em;
    color: var(--accent2);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .access-section p {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 24px;
    line-height: 1.6;
  }

  .access-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  @media (max-width: 600px) {
    .access-form { grid-template-columns: 1fr; }
  }

  .access-form input,
  .access-form textarea {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--sans);
    font-size: 13px;
    padding: 10px 14px;
    outline: none;
    transition: border-color 0.2s;
  }

  .access-form input:focus,
  .access-form textarea:focus {
    border-color: var(--accent2);
  }

  .access-form textarea {
    grid-column: 1 / -1;
    resize: vertical;
    min-height: 80px;
  }

  .access-form input::placeholder,
  .access-form textarea::placeholder {
    color: var(--muted);
  }

  .submit-btn {
    grid-column: 1 / -1;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 12px 24px;
    background: var(--accent2);
    border: none;
    color: #fff;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    font-weight: 700;
  }

  .submit-btn:hover { opacity: 0.85; }
  .submit-btn:active { transform: scale(0.99); }
  .submit-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .form-msg {
    grid-column: 1 / -1;
    font-family: var(--mono);
    font-size: 12px;
    padding: 10px 14px;
    display: none;
  }

  .form-msg.success { background: rgba(0,255,157,0.08); color: var(--accent); border: 1px solid rgba(0,255,157,0.2); }
  .form-msg.error { background: rgba(255,68,68,0.08); color: var(--danger); border: 1px solid rgba(255,68,68,0.2); }

  /* Loading */
  #loading {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--muted);
    padding: 48px 0;
    text-align: center;
  }

  #loading::after {
    content: '';
    animation: dots 1.5s infinite;
  }

  @keyframes dots {
    0% { content: ''; }
    33% { content: '.'; }
    66% { content: '..'; }
    100% { content: '...'; }
  }

  /* Empty state */
  #empty {
    display: none;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--muted);
    padding: 48px 0;
    text-align: center;
  }

  /* Footer */
  footer {
    margin-top: 64px;
    padding: 24px 0;
    border-top: 1px solid var(--border);
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }

  footer a { color: var(--accent); text-decoration: none; }
</style>
</head>
<body>

<div class="container">
  <header>
    <div class="header-inner">
      <div>
        <div class="brand">UnitedSys — United Systems | jwl247</div>
        <h1>AUTHENTIC<span>CODER</span><br>GLOSSARY</h1>
      </div>
      <div class="status-bar">
        <span class="status-dot"></span>
        <span id="worker-status">connecting...</span>
      </div>
    </div>
  </header>

  <div class="search-wrap">
    <input type="text" id="search" placeholder="search terms, definitions, categories..." autocomplete="off">
  </div>

  <div class="filters" id="filters">
    <button class="filter-btn active" data-cat="all">All</button>
  </div>

  <div class="stats" id="stats" style="display:none">
    <div>terms: <span id="count-shown">0</span></div>
    <div>total: <span id="count-total">0</span></div>
    <div>source: <span>packages-worker.phoenix-jwl.workers.dev</span></div>
  </div>

  <div id="loading">connecting to phoenix worker</div>
  <div id="empty">no terms found</div>
  <div id="glossary-grid"></div>

  <div class="access-section">
    <h2>// Request Glossary Access</h2>
    <p>Full glossary access requires an approved token. Submit your details and jwl247 will review your request via GitHub.</p>
    <div class="access-form" id="access-form">
      <input type="text" id="f-name" placeholder="your name" required>
      <input type="text" id="f-github" placeholder="github handle" required>
      <input type="email" id="f-email" placeholder="email address" required>
      <input type="text" id="f-role" placeholder="your role (optional)">
      <textarea id="f-reason" placeholder="why do you want access? (optional)"></textarea>
      <div class="form-msg" id="form-msg"></div>
      <button class="submit-btn" id="submit-btn" onclick="submitRequest()">// Request Access</button>
    </div>
  </div>

  <footer>
    <span>© 2026 UnitedSys — United Systems | jwl247</span>
    <span>GPL-3.0 — <a href="https://github.com/jwl247/Phoenix-Package_handler">GitHub</a></span>
  </footer>
</div>

<script>
  const WORKER = 'https://packages-worker.phoenix-jwl.workers.dev';
  const INSTALLER = 'https://pho-installer-worker.phoenix-jwl.workers.dev';

  let allTerms = [];
  let activeCategory = 'all';
  let searchQuery = '';

  const catClass = (cat) => {
    const map = { core: 'cat-core', application: 'cat-application', system: 'cat-system', storage: 'cat-storage', worker: 'cat-worker' };
    return map[cat?.toLowerCase()] || 'cat-default';
  };

  function renderCards(terms) {
    const grid = document.getElementById('glossary-grid');
    const empty = document.getElementById('empty');
    const stats = document.getElementById('stats');

    document.getElementById('count-shown').textContent = terms.length;

    if (terms.length === 0) {
      grid.innerHTML = '';
      empty.style.display = 'block';
      return;
    }

    empty.style.display = 'none';
    stats.style.display = 'flex';

    grid.innerHTML = terms.map((t, i) => {
      const name = t.name || t.term || '';
      const def = t.description || t.definition || '';
      const cat = t.category || 'general';
      const hex = t.hex || '';

      return `
        <div class="term-card" style="animation-delay: ${Math.min(i * 40, 400)}ms">
          <div class="term-header">
            <div class="term-name">${escapeHtml(name)}</div>
            <div class="term-category ${catClass(cat)}">${escapeHtml(cat)}</div>
          </div>
          <div class="term-def">${escapeHtml(def) || '<span style="color:var(--muted)">— no description yet —</span>'}</div>
          ${hex ? `<div class="term-hex">hex: ${escapeHtml(hex)}</div>` : ''}
        </div>
      `;
    }).join('');
  }

  function filterAndRender() {
    let terms = [...allTerms];
    if (activeCategory !== 'all') {
      terms = terms.filter(t => (t.category || '').toLowerCase() === activeCategory);
    }
    if (searchQuery) {
      const q = searchQuery.toLowerCase();
      terms = terms.filter(t =>
        (t.name || t.term || '').toLowerCase().includes(q) ||
        (t.description || t.definition || '').toLowerCase().includes(q)
      );
    }
    renderCards(terms);
  }

  function buildFilters(terms) {
    const cats = [...new Set(terms.map(t => t.category).filter(Boolean))].sort();
    const filtersEl = document.getElementById('filters');
    cats.forEach(cat => {
      const btn = document.createElement('button');
      btn.className = 'filter-btn';
      btn.dataset.cat = cat.toLowerCase();
      btn.textContent = cat;
      btn.onclick = () => {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategory = cat.toLowerCase();
        filterAndRender();
      };
      filtersEl.appendChild(btn);
    });

    document.querySelector('[data-cat="all"]').onclick = () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      document.querySelector('[data-cat="all"]').classList.add('active');
      activeCategory = 'all';
      filterAndRender();
    };
  }

  async function loadGlossary() {
    try {
      // Try packages-worker first (token-protected full glossary)
      // Fall back to installer worker public glossary
      let terms = [];

      try {
        const r = await fetch(`${WORKER}/glossary`);
        const d = await r.json();
        if (d.glossary && d.glossary.length > 0) {
          terms = d.glossary;
        }
      } catch(e) {}

      // Always also load from installer public glossary
      try {
        const r2 = await fetch(`${INSTALLER}/glossary`);
        const d2 = await r2.json();
        if (d2.results && d2.results.length > 0) {
          // Merge, deduplicate by name
          const existing = new Set(terms.map(t => t.name || t.term));
          d2.results.forEach(t => {
            const n = t.name || t.term;
            if (!existing.has(n)) { terms.push(t); existing.add(n); }
          });
        }
      } catch(e) {}

      if (terms.length === 0) throw new Error('No terms returned');

      allTerms = terms;
      document.getElementById('count-total').textContent = terms.length;
      document.getElementById('loading').style.display = 'none';
      document.getElementById('worker-status').textContent = `live — ${terms.length} terms`;
      buildFilters(terms);
      renderCards(terms);
      document.getElementById('stats').style.display = 'flex';

    } catch(e) {
      document.getElementById('loading').textContent = 'worker unreachable — check connection';
      document.getElementById('worker-status').textContent = 'offline';
    }
  }

  async function submitRequest() {
    const btn = document.getElementById('submit-btn');
    const msg = document.getElementById('form-msg');
    const name = document.getElementById('f-name').value.trim();
    const github = document.getElementById('f-github').value.trim();
    const email = document.getElementById('f-email').value.trim();
    const role = document.getElementById('f-role').value.trim();
    const reason = document.getElementById('f-reason').value.trim();

    if (!name || !github || !email) {
      msg.className = 'form-msg error';
      msg.textContent = '// name, github, and email are required';
      msg.style.display = 'block';
      return;
    }

    btn.disabled = true;
    btn.textContent = '// submitting...';
    msg.style.display = 'none';

    try {
      const r = await fetch(`${WORKER}/access-request`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, github, email, role, reason })
      });
      const d = await r.json();

      if (d.ok) {
        msg.className = 'form-msg success';
        msg.textContent = '// request received — jwl247 will review and approve via GitHub';
        msg.style.display = 'block';
        btn.textContent = '// request sent';
      } else if (d.status === 'approved') {
        msg.className = 'form-msg success';
        msg.textContent = '// already approved — check your email for your token';
        msg.style.display = 'block';
        btn.textContent = '// already approved';
      } else if (d.status === 'pending') {
        msg.className = 'form-msg success';
        msg.textContent = '// request already pending — jwl247 will review shortly';
        msg.style.display = 'block';
        btn.textContent = '// already submitted';
      } else {
        throw new Error(d.error || 'unknown error');
      }
    } catch(e) {
      msg.className = 'form-msg error';
      msg.textContent = `// error: ${e.message}`;
      msg.style.display = 'block';
      btn.disabled = false;
      btn.textContent = '// Request Access';
    }
  }

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  document.getElementById('search').addEventListener('input', e => {
    searchQuery = e.target.value.trim();
    filterAndRender();
  });

  loadGlossary();
</script>
</body>
</html>